/* login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  background-color: #f4f7fa;
}

.login-title {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.login-form {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 400rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 14rpx;
  color: #555;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  padding: 12rpx;
  margin-bottom: 15rpx;
  border-radius: 4rpx;
  border: 1rpx solid #ddd;
  font-size: 16rpx;
}

.input:focus {
  border-color: #4CAF50;
  outline: none;
  background-color: #fff;
}

.login-btn {
  width: 100%;
  padding: 14rpx;
  background-color: #4CAF50;
  color: white;
  border: none;
  border-radius: 4rpx;
  font-size: 16rpx;
  cursor: pointer;
  transition: background-color 0.3s;
}

.login-btn:hover {
  background-color: #45a049;
}

.product-description {
  margin-top: 40rpx;
  text-align: center;
  font-size: 16rpx;
  color: #666;
  max-width: 400rpx;
}

.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

.dialog {
  background-color: white;
  padding: 20rpx;
  border-radius: 8rpx;
  width: 80%;
  max-width: 400rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

.dialog-btn {
  background-color: #4CAF50;
  color: white;
  border: none;
  padding: 12rpx;
  width: 100%;
  border-radius: 4rpx;
  cursor: pointer;
}

.dialog-btn:hover {
  background-color: #45a049;
}

.dialog-close-btn {
  background-color: #f44336;
  color: white;
  border: none;
  padding: 12rpx;
  width: 100%;
  border-radius: 4rpx;
  cursor: pointer;
  margin-top: 10rpx;
}

.dialog-message {
  color: #f44336;
  font-size: 14rpx;
  margin-top: 15rpx;
}
