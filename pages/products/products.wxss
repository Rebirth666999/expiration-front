/* 页面容器 */
.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
  font-family: Arial, sans-serif;
}

/* 欢迎文字 */
.welcome {
  font-size: 18px;
  margin-bottom: 20px;
  color: #333;
}

/* 产品列表 */
.product-list {
  margin-top: 20px;
}

.product-title {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 10px;
}

/* 产品卡片 */
.product-card {
  background-color: #fff;
  padding: 20px;
  margin-bottom: 20px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: transform 0.2s;
}

.product-card:hover {
  transform: translateY(-5px);
}

/* 产品信息 */
.product-info {
  display: flex;
  flex-direction: column;
}

.product-name {
  font-weight: bold;
  font-size: 16px;
  margin-bottom: 5px;
}

.product-type,
.product-expiry {
  color: #555;
  font-size: 14px;
}

/* 按钮样式 */
.btn {
  padding: 8px 12px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-size: 14px;
}

.primary-btn {
  background-color: #007bff;
  color: white;
}

.primary-btn:hover {
  background-color: #0056b3;
}

.delete-btn {
  background-color: #ff4d4d;
  color: white;
}

.delete-btn:hover {
  background-color: #e43b3b;
}

/* 弹框遮罩 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹框内容 */
.dialog {
  background: white;
  padding: 20px;
  border-radius: 8px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  width: 90%;
  max-width: 400px;
  text-align: center;
}

.dialog .h3 {
  margin-bottom: 20px;
}

.dialog .input,
.dialog select {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border-radius: 4px;
  border: 1px solid #ddd;
}

.dialog .button {
  margin-top: 10px;
}

/* 无数据时的提示 */
.no-data {
  color: #999;
  font-size: 16px;
  text-align: center;
  margin-top: 20px;
}

/* 下拉选择框 */
.picker {
  padding: 10px;
  background-color: #f4f4f4;
  border-radius: 4px;
  margin-top: 5px;
}
